# background = 0a0a12
# background = 0d0d0d
# background = 000000
# background = 05080b
background = 0f0f11
foreground = ffffff

macos-titlebar-style = transparent
window-theme = light
# macos-non-native-fullscreen = true

window-width = 80
window-height = 25

# Terminal theme is rose-pine
# theme = Rose Pine
# theme = Apple Classic
theme = 0x96f

background-opacity=1
# background-blur=95

# font-family = "MesloLGS Nerd Font"
# font-family = "Terminus (TTF)"
# font-family = "templeos"
# font-family = "Input"

# Looks better
font-thicken = true
font-thicken-strength = 200
font-size=17

#This disables the warning before closing a window
confirm-close-surface = false

#When begin typing the mouse is not visible
mouse-hide-while-typing

# window-padding-x = 10
# window-padding-y = 10
window-padding-balance = true

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
