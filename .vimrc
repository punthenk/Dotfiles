set nocompatible
filetype indent on
syntax on
set wildmenu
set showcmd
set incsearch
set hlsearch
set ignorecase
set smartcase
set backspace=indent,eol,start
set autoindent
set nostartofline
set ruler
set laststatus=2
set confirm
set cmdheight=2
set number
set notimeout ttimeout ttimeoutlen=200
set tabstop=4
set shiftwidth=4
set softtabstop=4
set expandtab
map Y y$
nnoremap <C-L> :nohl<CR><C-L>
nnoremap - :Explore<CR>
